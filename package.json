{
  "name": "sleeper-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Sleeper Fantasy Sports API — exposes users, leagues, rosters, matchups, drafts, and player data to any MCP-compatible AI client",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sleeper-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prepare": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "sleeper",
    "fantasy-sports",
    "fantasy-football",
    "nfl",
    "claude",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
